# Public URLs
NEXT_PUBLIC_SERVER_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_CONNECTION_URL=ws://localhost:8080
NEXT_PUBLIC_EXECUTION_SERVICE_URL=http://localhost:8000
BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cide

# Auth
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret

GITHUB_CLIENT_ID=replace_with_github_client_id
GITHUB_CLIENT_SECRET=replace_with_github_client_secret

# Room JWT (must match server/.env)
JWT_SECRET=replace_with_the_same_secret_used_in_server

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Code execution
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_API_KEY=
RESULT_TTL_SECONDS=3600
